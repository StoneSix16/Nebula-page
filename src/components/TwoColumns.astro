---
interface Props {
  /** Flex ratios for [left, right] columns. Default [1, 1] for equal widths. */
  widths?: [number, number];
  children?: any;
}

const { widths = [1, 1] } = Astro.props;
const [left, right] = widths;
---

<div class="flex w-full flex-wrap items-center gap-4 my-0 ">
  <div class="min-w-[16rem]" flex-[1] style={`flex: ${left}`}>
    <slot name="left" />
  </div>
  <div class="min-w-[16rem]" flex-[1] style={`flex: ${right}`}>
    <slot name="right" />
  </div>
</div>
